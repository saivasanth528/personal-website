---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout
  title="Blog — Sai Vasanth"
  description="Thoughts on software engineering, system design, and technology."
>
  <Nav />
  <main>
    <section class="blog-hero">
      <div class="container">
        <p class="section-label">Blog</p>
        <h1 class="section-title">Thoughts &<br /><span class="gradient-text">Writings</span></h1>
        <p class="subtitle">
          Ideas on software engineering, system design, and things I find genuinely interesting.
        </p>
      </div>
    </section>

    <section class="blog-list">
      <div class="container">
        {
          posts.length === 0 ? (
            <p class="empty">No posts yet. Check back soon.</p>
          ) : (
            <div class="posts">
              {posts.map((post) => (
                <a href={`/blog/${post.slug}`} class="post-card">
                  <div class="post-meta">
                    <span class="post-date">
                      {new Date(post.data.pubDate).toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric',
                      })}
                    </span>
                    <div class="post-tags">
                      {post.data.tags.map((tag: string) => (
                        <span class="ptag">{tag}</span>
                      ))}
                    </div>
                  </div>
                  <h2 class="post-title">{post.data.title}</h2>
                  <p class="post-excerpt">{post.data.description}</p>
                  <span class="read-more">Read more →</span>
                </a>
              ))}
            </div>
          )
        }
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .blog-hero {
    padding: 9rem 0 3rem;
  }

  .subtitle {
    color: var(--muted);
    font-size: 0.95rem;
    margin-top: 1rem;
    max-width: 460px;
    line-height: 1.7;
  }

  .blog-list {
    padding-bottom: 6rem;
  }

  .empty {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: var(--muted);
    text-align: center;
    padding: 5rem 0;
  }

  .posts {
    display: flex;
    flex-direction: column;
  }

  .post-card {
    display: block;
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .post-card:hover .post-title {
    color: var(--accent);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .post-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    color: var(--muted);
    letter-spacing: 0.1em;
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
  }

  .ptag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    color: var(--accent);
    background: rgba(6, 182, 212, 0.07);
    border: 1px solid rgba(6, 182, 212, 0.18);
    padding: 0.15rem 0.55rem;
    border-radius: 4px;
  }

  .post-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(1.2rem, 3vw, 1.65rem);
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.75rem;
    transition: color 0.2s ease;
    line-height: 1.2;
  }

  .post-excerpt {
    font-size: 0.88rem;
    color: var(--muted);
    line-height: 1.75;
    margin-bottom: 1rem;
    max-width: 640px;
  }

  .read-more {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: var(--accent);
    letter-spacing: 0.05em;
  }
</style>
