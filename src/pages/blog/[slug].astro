---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout title={`${post.data.title} — Sai Vasanth`} description={post.data.description}>
  <Nav />
  <main>
    <article class="article">
      <div class="container">
        <a href="/blog" class="back">← Back to Blog</a>

        <header class="article-header">
          <div class="meta">
            <span class="date">
              {
                new Date(post.data.pubDate).toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })
              }
            </span>
            <div class="tags">
              {
                post.data.tags.map((tag: string) => (
                  <span class="ptag">{tag}</span>
                ))
              }
            </div>
          </div>
          <h1 class="article-title">{post.data.title}</h1>
          <p class="article-desc">{post.data.description}</p>
        </header>

        <div class="content">
          <Content />
        </div>
      </div>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  .article {
    padding: 9rem 0 6rem;
  }

  .back {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: 0.05em;
    display: inline-block;
    margin-bottom: 3rem;
    transition: color 0.2s ease;
  }

  .back:hover {
    color: var(--accent);
  }

  .article-header {
    max-width: 720px;
    margin-bottom: 3rem;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    color: var(--muted);
    letter-spacing: 0.1em;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
  }

  .ptag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    color: var(--accent);
    background: rgba(6, 182, 212, 0.07);
    border: 1px solid rgba(6, 182, 212, 0.18);
    padding: 0.15rem 0.55rem;
    border-radius: 4px;
  }

  .article-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .article-desc {
    font-size: 1.05rem;
    color: var(--muted);
    line-height: 1.75;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--border);
  }

  /* Prose styles */
  .content {
    max-width: 720px;
    font-size: 1rem;
    line-height: 1.85;
    color: var(--muted);
  }

  .content :global(h2) {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.65rem;
    font-weight: 600;
    color: var(--text);
    margin: 2.5rem 0 1rem;
    letter-spacing: -0.01em;
  }

  .content :global(h3) {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text);
    margin: 2rem 0 0.75rem;
  }

  .content :global(p) {
    margin-bottom: 1.5rem;
  }

  .content :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .content :global(code) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.84em;
    color: var(--accent);
    background: rgba(6, 182, 212, 0.08);
    border: 1px solid rgba(6, 182, 212, 0.15);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .content :global(pre) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
    overflow-x: auto;
    margin: 2rem 0;
  }

  .content :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: var(--text);
    font-size: 0.875rem;
  }

  .content :global(ul),
  .content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .content :global(li) {
    margin-bottom: 0.5rem;
  }

  .content :global(blockquote) {
    border-left: 2px solid var(--accent);
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-style: italic;
    color: var(--muted);
  }

  .content :global(img) {
    width: 100%;
    border-radius: 8px;
    margin: 2rem 0;
  }

  .content :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }
</style>
