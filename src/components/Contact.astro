---
const socials = [
  { name: 'GitHub', href: 'https://github.com/saivasanth528' },
  { name: 'LinkedIn', href: 'https://linkedin.com/in/sai-vasanth' },
  { name: 'LeetCode', href: 'https://leetcode.com/saivasanth' },
];
---

<section id="contact">
  <div class="container">
    <div class="contact-inner reveal">
      <p class="section-label">Contact</p>
      <h2 class="section-title">
        Let's Work<br /><span class="gradient-text">Together</span>
      </h2>
      <p class="contact-text">
        Open to interesting engineering challenges, leadership roles, and good conversations.
        Whether it's a new opportunity or just a question — my inbox is open.
      </p>

      <a href="mailto:vasisai128@gmail.com" class="email-link">
        vasisai128@gmail.com
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"></path>
        </svg>
      </a>

      <div class="socials">
        {socials.map((s) => (
          <a href={s.href} target="_blank" rel="noopener noreferrer" class="social-link">
            {s.name}
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .contact-inner {
    text-align: center;
    max-width: 540px;
    margin: 0 auto;
  }

  .contact-inner .section-label {
    justify-content: center;
  }

  .contact-inner .section-label::before {
    display: none;
  }

  .contact-text {
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.85;
    margin: 1.5rem 0 2.5rem;
  }

  .email-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    font-weight: 500;
    color: var(--text);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 3px;
    transition: color 0.2s ease;
    margin-bottom: 3rem;
  }

  .email-link svg { color: var(--accent); }
  .email-link:hover { color: var(--accent); }

  .socials {
    display: flex;
    justify-content: center;
    gap: 2.5rem;
  }

  .social-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s ease;
    position: relative;
  }

  .social-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--accent);
    transition: width 0.2s ease;
  }

  .social-link:hover { color: var(--accent); }
  .social-link:hover::after { width: 100%; }
</style>
